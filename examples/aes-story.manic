  par { fade(f_xor, 0.15); recolor(st, lime, 0.2); say(st.r0c0, "69", 0.25); say(st.r0c1, "6a", 0.25); say(st.r0c2, "d8", 0.25); say(st.r0c3, "70", 0.25); say(st.r1c0, "c4", 0.25); say(st.r1c1, "7b", 0.25); say(st.r1c2, "cd", 0.25); say(st.r1c3, "b4", 0.25); say(st.r2c0, "e0", 0.25); say(st.r2c1, "04", 0.25); say(st.r2c2, "b7", 0.25); say(st.r2c3, "c5", 0.25); say(st.r3c0, "d8", 0.25); say(st.r3c1, "30", 0.25); say(st.r3c2, "80", 0.25); say(st.r3c3, "5a", 0.25); }
  par { fade(sbox, 0.2); fade(rk, 0.2); fade(rklab, 0.2); }
  say(cap, "Ciphertext", 0.2);
  say(exp, "The state is read out column by column as the 16-byte ciphertext.", 0.2);
}
  recolor(st, fg, 0.25);
wait(0.35);

par { recolor(st, lime, 0.4); fade(sbox, 0.2); fade(rk, 0.2); fade(rklab, 0.2); }
pulse(st, 0.8);
text(done, (cx, h - 250), "ciphertext  69c4e0d86a7b0430d8cdb78070b4c55a");  size(done, 22); color(done, lime); hidden(done);
show(done, 0.5);
