title("AES-128 — How It Works");
canvas("portrait");
template("mono");

text(hdr, (cx, 120), "AES-128 · encrypt");  size(hdr, 42); bold(hdr); color(hdr, cyan);

// --- FULL FLOW strip (you-are-here) ---
text(chip0, (270, 210), "SubBytes");  size(chip0, 19); color(chip0, dim);
text(chip1, (490, 210), "ShiftRows");  size(chip1, 19); color(chip1, dim);
text(chip2, (700, 210), "MixColumns");  size(chip2, 19); color(chip2, dim);
text(chip3, (900, 210), "AddRoundKey");  size(chip3, 19); color(chip3, dim);
text(loop, (cx, 250), "the round repeats x10");  size(loop, 18); color(loop, dim);
text(rnd, (cx, 300), "");  size(rnd, 24); color(rnd, cyan); bold(rnd);

// --- the live 4x4 state (cells relabelled + highlighted in place) ---
matrix(st, "00 44 88 cc; 11 55 99 dd; 22 66 aa ee; 33 77 bb ff", (cx, cy - 40), 150, 132);

// --- formulas (one per op, shown when active) ---
equation(f_sub,   (cx, cy - 470), `b' = S(b)`, 40);            hidden(f_sub);
equation(f_shift, (cx, cy - 470), `\text{row } r \lll r`, 40);  hidden(f_shift);
equation(f_mix,   (cx, cy - 470), `c' = M\,c`, 40);            hidden(f_mix);
equation(f_xor,   (cx, cy - 470), `\text{state} \oplus K_n`, 40); hidden(f_xor);

// --- secondary beat: S-box lookup callout (SubBytes) / round key (AddRoundKey) ---
text(sbox, (cx, cy + 430), "");  size(sbox, 26); color(sbox, cyan);  hidden(sbox);
matrix(rk, "00 00 00 00; 00 00 00 00; 00 00 00 00; 00 00 00 00", (cx, cy + 470), 120, 96);
color(rk, lime); hidden(rk);
text(rklab, (cx, cy + 300), "round key");  size(rklab, 20); color(rklab, dim); hidden(rklab);

text(cap, (cx, h - 210), "");   size(cap, 28); wrap(cap, w*0.82); bold(cap);
text(exp, (cx, h - 150), "");   size(exp, 22); color(exp, dim); wrap(exp, w*0.84);
text(mark, (w - 150, h - 44), "Made with Manic");  size(mark, 22); color(mark, dim);

// ---------- timeline ----------
show(hdr, 0.4); show(mark, 0.4);
show(chip0, 0.3);
show(chip1, 0.3);
show(chip2, 0.3);
show(chip3, 0.3);
show(loop, 0.3); show(st, 0.5);
say(cap, "Load plaintext", 0.3);
say(exp, "The 16-byte key splits into four 32-bit words w0..w3 — this is the first round key. The ot", 0.3);
wait(0.8);

step("Round 0 · xor") {
  recolor(chip0, dim, 0.15);
  recolor(chip1, dim, 0.15);
  recolor(chip2, dim, 0.15);
  recolor(chip3, lime, 0.15);
  say(rnd, "initial", 0.15);
  par { show(f_xor, 0.2); recolor(st, lime, 0.2); say(st.r0c0, "00", 0.25); say(st.r0c1, "40", 0.25); say(st.r0c2, "80", 0.25); say(st.r0c3, "c0", 0.25); say(st.r1c0, "10", 0.25); say(st.r1c1, "50", 0.25); say(st.r1c2, "90", 0.25); say(st.r1c3, "d0", 0.25); say(st.r2c0, "20", 0.25); say(st.r2c1, "60", 0.25); say(st.r2c2, "a0", 0.25); say(st.r2c3, "e0", 0.25); say(st.r3c0, "30", 0.25); say(st.r3c1, "70", 0.25); say(st.r3c2, "b0", 0.25); say(st.r3c3, "f0", 0.25); }
  say(rk.r0c0, "00", 0.1); say(rk.r0c1, "04", 0.1); say(rk.r0c2, "08", 0.1); say(rk.r0c3, "0c", 0.1);
  say(rk.r1c0, "01", 0.1); say(rk.r1c1, "05", 0.1); say(rk.r1c2, "09", 0.1); say(rk.r1c3, "0d", 0.1);
  say(rk.r2c0, "02", 0.1); say(rk.r2c1, "06", 0.1); say(rk.r2c2, "0a", 0.1); say(rk.r2c3, "0e", 0.1);
  say(rk.r3c0, "03", 0.1); say(rk.r3c1, "07", 0.1); say(rk.r3c2, "0b", 0.1); say(rk.r3c3, "0f", 0.1);
  par { show(rk, 0.2); show(rklab, 0.2); fade(sbox, 0.2); }
  say(cap, "AddRoundKey", 0.2);
  say(exp, "Each state byte is XORed with the matching round-key byte.", 0.2);
}
  recolor(st, fg, 0.25);
wait(0.35);
step("Round 1 · sub") {
  recolor(chip0, cyan, 0.15);
  recolor(chip1, dim, 0.15);
  recolor(chip2, dim, 0.15);
  recolor(chip3, dim, 0.15);
  say(rnd, "Round 1 / 10", 0.15);
  par { fade(f_xor, 0.15); show(f_sub, 0.2); recolor(st, cyan, 0.2); say(st.r0c0, "63", 0.25); say(st.r0c1, "09", 0.25); say(st.r0c2, "cd", 0.25); say(st.r0c3, "ba", 0.25); say(st.r1c0, "ca", 0.25); say(st.r1c1, "53", 0.25); say(st.r1c2, "60", 0.25); say(st.r1c3, "70", 0.25); say(st.r2c0, "b7", 0.25); say(st.r2c1, "d0", 0.25); say(st.r2c2, "e0", 0.25); say(st.r2c3, "e1", 0.25); say(st.r3c0, "04", 0.25); say(st.r3c1, "51", 0.25); say(st.r3c2, "e7", 0.25); say(st.r3c3, "8c", 0.25); }
  par { say(sbox, "S-box:  00→63  10→ca  20→b7", 0.2); show(sbox, 0.2); fade(rk, 0.2); fade(rklab, 0.2); }
  say(cap, "SubBytes", 0.2);
  say(exp, "Each byte is replaced via the S-box (row = high nibble, col = low nibble).", 0.2);
}
  recolor(st, fg, 0.25);
wait(0.35);
step("Round 1 · permute") {
  recolor(chip0, dim, 0.15);
  recolor(chip1, gold, 0.15);
  recolor(chip2, dim, 0.15);
  recolor(chip3, dim, 0.15);
  say(rnd, "Round 1 / 10", 0.15);
  par { fade(f_sub, 0.15); show(f_shift, 0.2); recolor(st, gold, 0.2); say(st.r0c0, "63", 0.25); say(st.r0c1, "09", 0.25); say(st.r0c2, "cd", 0.25); say(st.r0c3, "ba", 0.25); say(st.r1c0, "53", 0.25); say(st.r1c1, "60", 0.25); say(st.r1c2, "70", 0.25); say(st.r1c3, "ca", 0.25); say(st.r2c0, "e0", 0.25); say(st.r2c1, "e1", 0.25); say(st.r2c2, "b7", 0.25); say(st.r2c3, "d0", 0.25); say(st.r3c0, "8c", 0.25); say(st.r3c1, "04", 0.25); say(st.r3c2, "51", 0.25); say(st.r3c3, "e7", 0.25); }
  par { fade(sbox, 0.2); fade(rk, 0.2); fade(rklab, 0.2); }
  say(cap, "ShiftRows", 0.2);
  say(exp, "Row 0 is unchanged; row r is cyclically left-shifted by r bytes.", 0.2);
}
  recolor(st, fg, 0.25);
wait(0.35);
step("Round 1 · mix") {
  recolor(chip0, dim, 0.15);
  recolor(chip1, dim, 0.15);
  recolor(chip2, magenta, 0.15);
  recolor(chip3, dim, 0.15);
  say(rnd, "Round 1 / 10", 0.15);
  par { fade(f_shift, 0.15); show(f_mix, 0.2); recolor(st, magenta, 0.2); say(st.r0c0, "5f", 0.25); say(st.r0c1, "57", 0.25); say(st.r0c2, "f7", 0.25); say(st.r0c3, "1d", 0.25); say(st.r1c0, "72", 0.25); say(st.r1c1, "f5", 0.25); say(st.r1c2, "be", 0.25); say(st.r1c3, "b9", 0.25); say(st.r2c0, "64", 0.25); say(st.r2c1, "bc", 0.25); say(st.r2c2, "3b", 0.25); say(st.r2c3, "f9", 0.25); say(st.r3c0, "15", 0.25); say(st.r3c1, "92", 0.25); say(st.r3c2, "29", 0.25); say(st.r3c3, "1a", 0.25); }
  par { fade(sbox, 0.2); fade(rk, 0.2); fade(rklab, 0.2); }
  say(cap, "MixColumns", 0.2);
  say(exp, "Each column is multiplied by the fixed AES matrix over GF(2^8).", 0.2);
}
  recolor(st, fg, 0.25);
wait(0.35);
step("Round 1 · xor") {
  recolor(chip0, dim, 0.15);
  recolor(chip1, dim, 0.15);
  recolor(chip2, dim, 0.15);
  recolor(chip3, lime, 0.15);
  say(rnd, "Round 1 / 10", 0.15);
  par { fade(f_mix, 0.15); show(f_xor, 0.2); recolor(st, lime, 0.2); say(st.r0c0, "89", 0.25); say(st.r0c1, "85", 0.25); say(st.r0c2, "2d", 0.25); say(st.r0c3, "cb", 0.25); say(st.r1c0, "d8", 0.25); say(st.r1c1, "5a", 0.25); say(st.r1c2, "18", 0.25); say(st.r1c3, "12", 0.25); say(st.r2c0, "10", 0.25); say(st.r2c1, "ce", 0.25); say(st.r2c2, "43", 0.25); say(st.r2c3, "8f", 0.25); say(st.r3c0, "e8", 0.25); say(st.r3c1, "68", 0.25); say(st.r3c2, "d8", 0.25); say(st.r3c3, "e4", 0.25); }
  say(rk.r0c0, "d6", 0.1); say(rk.r0c1, "d2", 0.1); say(rk.r0c2, "da", 0.1); say(rk.r0c3, "d6", 0.1);
  say(rk.r1c0, "aa", 0.1); say(rk.r1c1, "af", 0.1); say(rk.r1c2, "a6", 0.1); say(rk.r1c3, "ab", 0.1);
  say(rk.r2c0, "74", 0.1); say(rk.r2c1, "72", 0.1); say(rk.r2c2, "78", 0.1); say(rk.r2c3, "76", 0.1);
  say(rk.r3c0, "fd", 0.1); say(rk.r3c1, "fa", 0.1); say(rk.r3c2, "f1", 0.1); say(rk.r3c3, "fe", 0.1);
  par { show(rk, 0.2); show(rklab, 0.2); fade(sbox, 0.2); }
  say(cap, "AddRoundKey", 0.2);
  say(exp, "Each state byte is XORed with the matching round-key byte.", 0.2);
}
  recolor(st, fg, 0.25);
wait(0.35);
step("Round 2 · sub") {
  recolor(chip0, cyan, 0.15);
  recolor(chip1, dim, 0.15);
  recolor(chip2, dim, 0.15);
  recolor(chip3, dim, 0.15);
  say(rnd, "Round 2 / 10", 0.15);
  par { fade(f_xor, 0.15); show(f_sub, 0.2); recolor(st, cyan, 0.2); say(st.r0c0, "a7", 0.25); say(st.r0c1, "97", 0.25); say(st.r0c2, "d8", 0.25); say(st.r0c3, "1f", 0.25); say(st.r1c0, "61", 0.25); say(st.r1c1, "be", 0.25); say(st.r1c2, "ad", 0.25); say(st.r1c3, "c9", 0.25); say(st.r2c0, "ca", 0.25); say(st.r2c1, "8b", 0.25); say(st.r2c2, "1a", 0.25); say(st.r2c3, "73", 0.25); say(st.r3c0, "9b", 0.25); say(st.r3c1, "45", 0.25); say(st.r3c2, "61", 0.25); say(st.r3c3, "69", 0.25); }
  par { say(sbox, "S-box:  89→a7  d8→61  10→ca", 0.2); show(sbox, 0.2); fade(rk, 0.2); fade(rklab, 0.2); }
  say(cap, "SubBytes", 0.2);
  say(exp, "Each byte is replaced via the S-box (row = high nibble, col = low nibble).", 0.2);
}
  recolor(st, fg, 0.25);
wait(0.35);
step("Round 2 · permute") {
  recolor(chip0, dim, 0.15);
  recolor(chip1, gold, 0.15);
  recolor(chip2, dim, 0.15);
  recolor(chip3, dim, 0.15);
  say(rnd, "Round 2 / 10", 0.15);
  par { fade(f_sub, 0.15); show(f_shift, 0.2); recolor(st, gold, 0.2); say(st.r0c0, "a7", 0.25); say(st.r0c1, "97", 0.25); say(st.r0c2, "d8", 0.25); say(st.r0c3, "1f", 0.25); say(st.r1c0, "be", 0.25); say(st.r1c1, "ad", 0.25); say(st.r1c2, "c9", 0.25); say(st.r1c3, "61", 0.25); say(st.r2c0, "1a", 0.25); say(st.r2c1, "73", 0.25); say(st.r2c2, "ca", 0.25); say(st.r2c3, "8b", 0.25); say(st.r3c0, "69", 0.25); say(st.r3c1, "9b", 0.25); say(st.r3c2, "45", 0.25); say(st.r3c3, "61", 0.25); }
  par { fade(sbox, 0.2); fade(rk, 0.2); fade(rklab, 0.2); }
  say(cap, "ShiftRows", 0.2);
  say(exp, "Row 0 is unchanged; row r is cyclically left-shifted by r bytes.", 0.2);
}
  recolor(st, fg, 0.25);
wait(0.35);
step("Round 2 · mix") {
  recolor(chip0, dim, 0.15);
  recolor(chip1, dim, 0.15);
  recolor(chip2, magenta, 0.15);
  recolor(chip3, dim, 0.15);
  say(rnd, "Round 2 / 10", 0.15);
  par { fade(f_shift, 0.15); show(f_mix, 0.2); recolor(st, magenta, 0.2); say(st.r0c0, "ff", 0.25); say(st.r0c1, "31", 0.25); say(st.r0c2, "64", 0.25); say(st.r0c3, "77", 0.25); say(st.r1c0, "87", 0.25); say(st.r1c1, "d8", 0.25); say(st.r1c2, "51", 0.25); say(st.r1c3, "3a", 0.25); say(st.r2c0, "96", 0.25); say(st.r2c1, "6a", 0.25); say(st.r2c2, "51", 0.25); say(st.r2c3, "d0", 0.25); say(st.r3c0, "84", 0.25); say(st.r3c1, "51", 0.25); say(st.r3c2, "fa", 0.25); say(st.r3c3, "09", 0.25); }
  par { fade(sbox, 0.2); fade(rk, 0.2); fade(rklab, 0.2); }
  say(cap, "MixColumns", 0.2);
  say(exp, "Each column is multiplied by the fixed AES matrix over GF(2^8).", 0.2);
}
  recolor(st, fg, 0.25);
wait(0.35);
step("Round 2 · xor") {
  recolor(chip0, dim, 0.15);
  recolor(chip1, dim, 0.15);
  recolor(chip2, dim, 0.15);
  recolor(chip3, lime, 0.15);
  say(rnd, "Round 2 / 10", 0.15);
  par { fade(f_mix, 0.15); show(f_xor, 0.2); recolor(st, lime, 0.2); say(st.r0c0, "49", 0.25); say(st.r0c1, "55", 0.25); say(st.r0c2, "da", 0.25); say(st.r0c3, "1f", 0.25); say(st.r1c0, "15", 0.25); say(st.r1c1, "e5", 0.25); say(st.r1c2, "ca", 0.25); say(st.r1c3, "0a", 0.25); say(st.r2c0, "59", 0.25); say(st.r2c1, "d7", 0.25); say(st.r2c2, "94", 0.25); say(st.r2c3, "63", 0.25); say(st.r3c0, "8f", 0.25); say(st.r3c1, "a0", 0.25); say(st.r3c2, "fa", 0.25); say(st.r3c3, "f7", 0.25); }
  say(rk.r0c0, "b6", 0.1); say(rk.r0c1, "64", 0.1); say(rk.r0c2, "be", 0.1); say(rk.r0c3, "68", 0.1);
  say(rk.r1c0, "92", 0.1); say(rk.r1c1, "3d", 0.1); say(rk.r1c2, "9b", 0.1); say(rk.r1c3, "30", 0.1);
  say(rk.r2c0, "cf", 0.1); say(rk.r2c1, "bd", 0.1); say(rk.r2c2, "c5", 0.1); say(rk.r2c3, "b3", 0.1);
  say(rk.r3c0, "0b", 0.1); say(rk.r3c1, "f1", 0.1); say(rk.r3c2, "00", 0.1); say(rk.r3c3, "fe", 0.1);
  par { show(rk, 0.2); show(rklab, 0.2); fade(sbox, 0.2); }
  say(cap, "AddRoundKey", 0.2);
  say(exp, "Each state byte is XORed with the matching round-key byte.", 0.2);
}
  recolor(st, fg, 0.25);
wait(0.35);
step("Round 3 · sub") {
  recolor(chip0, cyan, 0.15);
  recolor(chip1, dim, 0.15);
  recolor(chip2, dim, 0.15);
  recolor(chip3, dim, 0.15);
  say(rnd, "Round 3 / 10", 0.15);
  par { fade(f_xor, 0.15); show(f_sub, 0.2); recolor(st, cyan, 0.2); say(st.r0c0, "3b", 0.25); say(st.r0c1, "fc", 0.25); say(st.r0c2, "57", 0.25); say(st.r0c3, "c0", 0.25); say(st.r1c0, "59", 0.25); say(st.r1c1, "d9", 0.25); say(st.r1c2, "74", 0.25); say(st.r1c3, "67", 0.25); say(st.r2c0, "cb", 0.25); say(st.r2c1, "0e", 0.25); say(st.r2c2, "22", 0.25); say(st.r2c3, "fb", 0.25); say(st.r3c0, "73", 0.25); say(st.r3c1, "e0", 0.25); say(st.r3c2, "2d", 0.25); say(st.r3c3, "68", 0.25); }
  par { say(sbox, "S-box:  49→3b  15→59  59→cb", 0.2); show(sbox, 0.2); fade(rk, 0.2); fade(rklab, 0.2); }
  say(cap, "SubBytes", 0.2);
  say(exp, "Each byte is replaced via the S-box (row = high nibble, col = low nibble).", 0.2);
}
  recolor(st, fg, 0.25);
wait(0.35);
step("Round 3 · permute") {
  recolor(chip0, dim, 0.15);
  recolor(chip1, gold, 0.15);
  recolor(chip2, dim, 0.15);
  recolor(chip3, dim, 0.15);
  say(rnd, "Round 3 / 10", 0.15);
  par { fade(f_sub, 0.15); show(f_shift, 0.2); recolor(st, gold, 0.2); say(st.r0c0, "3b", 0.25); say(st.r0c1, "fc", 0.25); say(st.r0c2, "57", 0.25); say(st.r0c3, "c0", 0.25); say(st.r1c0, "d9", 0.25); say(st.r1c1, "74", 0.25); say(st.r1c2, "67", 0.25); say(st.r1c3, "59", 0.25); say(st.r2c0, "22", 0.25); say(st.r2c1, "fb", 0.25); say(st.r2c2, "cb", 0.25); say(st.r2c3, "0e", 0.25); say(st.r3c0, "68", 0.25); say(st.r3c1, "73", 0.25); say(st.r3c2, "e0", 0.25); say(st.r3c3, "2d", 0.25); }
  par { fade(sbox, 0.2); fade(rk, 0.2); fade(rklab, 0.2); }
  say(cap, "ShiftRows", 0.2);
  say(exp, "Row 0 is unchanged; row r is cyclically left-shifted by r bytes.", 0.2);
}
  recolor(st, fg, 0.25);
wait(0.35);
step("Round 3 · mix") {
  recolor(chip0, dim, 0.15);
  recolor(chip1, dim, 0.15);
  recolor(chip2, magenta, 0.15);
  recolor(chip3, dim, 0.15);
  say(rnd, "Round 3 / 10", 0.15);
  par { fade(f_shift, 0.15); show(f_mix, 0.2); recolor(st, magenta, 0.2); say(st.r0c0, "4c", 0.25); say(st.r0c1, "f7", 0.25); say(st.r0c2, "2c", 0.25); say(st.r0c3, "53", 0.25); say(st.r1c0, "9c", 0.25); say(st.r1c1, "71", 0.25); say(st.r1c2, "3f", 0.25); say(st.r1c3, "4d", 0.25); say(st.r2c0, "1e", 0.25); say(st.r2c1, "f0", 0.25); say(st.r2c2, "86", 0.25); say(st.r2c3, "f2", 0.25); say(st.r3c0, "66", 0.25); say(st.r3c1, "76", 0.25); say(st.r3c2, "8e", 0.25); say(st.r3c3, "56", 0.25); }
  par { fade(sbox, 0.2); fade(rk, 0.2); fade(rklab, 0.2); }
  say(cap, "MixColumns", 0.2);
  say(exp, "Each column is multiplied by the fixed AES matrix over GF(2^8).", 0.2);
}
  recolor(st, fg, 0.25);
wait(0.35);
step("Round 3 · xor") {
  recolor(chip0, dim, 0.15);
  recolor(chip1, dim, 0.15);
  recolor(chip2, dim, 0.15);
  recolor(chip3, lime, 0.15);
  say(rnd, "Round 3 / 10", 0.15);
