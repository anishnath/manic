title("Limit At Infinity");
canvas("16:9");

let gx = cx + 230;
let gy = cy + 215;
let sx = 4.1;
let sy = 38;

let ax = cx - 330;
let ay = cy - 70;

text(head, (cx, 55), "creative visual: limit at infinity");
display(head);
color(head, cyan);
size(head, 34);
hidden(head);

text(cap, (cx, h - 48), "");
display(cap);
color(cap, fg);
size(cap, 21);
hidden(cap);

text(problem, (cx, 112), "lim x -> infinity  (5x^3 - 2x + 7) / (x^3 + 4x^2 + 3)");
display(problem);
color(problem, lime);
size(problem, 28);
hidden(problem);

text(stepTitle, (ax, ay - 70), "the infinity trick");
display(stepTitle);
color(stepTitle, cyan);
size(stepTitle, 30);
hidden(stepTitle);

rect(fracBox, (ax, ay + 20), 430, 150);
outline(fracBox, dim);
stroke(fracBox, 3);
hidden(fracBox);

text(num0, (ax, ay - 5), "5x^3 - 2x + 7");
text(den0, (ax, ay + 55), "x^3 + 4x^2 + 3");
display(num0);
display(den0);
color(num0, fg);
color(den0, fg);
size(num0, 26);
size(den0, 26);
hidden(num0);
hidden(den0);

line(fracLine0, (ax - 165, ay + 25), (ax + 165, ay + 25));
color(fracLine0, fg);
stroke(fracLine0, 3);
untraced(fracLine0);

arrow(divArrow, (ax, ay + 130), (ax, ay + 205));
color(divArrow, magenta);
stroke(divArrow, 5);
glow(divArrow, 7);
untraced(divArrow);

text(divText, (ax + 135, ay + 165), "divide top and bottom by x^3");
display(divText);
color(divText, magenta);
size(divText, 20);
hidden(divText);

rect(fracBox2, (ax, ay + 280), 470, 160);
outline(fracBox2, cyan);
stroke(fracBox2, 3);
hidden(fracBox2);

text(num1a, (ax - 78, ay + 250), "5");
text(num1b, (ax + 10, ay + 250), "- 2/x^2");
text(num1c, (ax + 122, ay + 250), "+ 7/x^3");
text(den1a, (ax - 78, ay + 315), "1");
text(den1b, (ax + 10, ay + 315), "+ 4/x");
text(den1c, (ax + 122, ay + 315), "+ 3/x^3");
display(num1a);
display(num1b);
display(num1c);
display(den1a);
display(den1b);
display(den1c);
color(num1a, lime);
color(num1b, magenta);
color(num1c, magenta);
color(den1a, lime);
color(den1b, magenta);
color(den1c, magenta);
size(num1a, 29);
size(num1b, 24);
size(num1c, 24);
size(den1a, 29);
size(den1b, 24);
size(den1c, 24);
hidden(num1a);
hidden(num1b);
hidden(num1c);
hidden(den1a);
hidden(den1b);
hidden(den1c);

line(fracLine1, (ax - 190, ay + 282), (ax + 190, ay + 282));
color(fracLine1, fg);
stroke(fracLine1, 3);
untraced(fracLine1);

text(vanish, (ax, ay + 395), "as x grows:  1/x, 1/x^2, 1/x^3 -> 0");
display(vanish);
color(vanish, cyan);
size(vanish, 23);
hidden(vanish);

text(finalMiniTop, (ax - 30, ay + 465), "5");
text(finalMiniBot, (ax - 30, ay + 525), "1");
line(finalMiniLine, (ax - 80, ay + 493), (ax + 20, ay + 493));
text(finalMiniEq, (ax + 130, ay + 493), "= 5");
display(finalMiniTop);
display(finalMiniBot);
display(finalMiniEq);
color(finalMiniTop, lime);
color(finalMiniBot, lime);
color(finalMiniEq, gold);
size(finalMiniTop, 34);
size(finalMiniBot, 34);
size(finalMiniEq, 42);
hidden(finalMiniTop);
hidden(finalMiniBot);
hidden(finalMiniEq);
color(finalMiniLine, fg);
stroke(finalMiniLine, 3);
untraced(finalMiniLine);

axes(axGraph, (gx, gy), 360, 245, 40);
color(axGraph, dim);
stroke(axGraph, 2);
untraced(axGraph);

plot(ratioCurve, (gx, gy), sx, sy, "(5x^3-2x+7)/(x^3+4*x^2+3)", (1, 80));
color(ratioCurve, cyan);
stroke(ratioCurve, 4);
glow(ratioCurve, 8);
untraced(ratioCurve);

line(asym, (gx + sx, gy - 5sy), (gx + 80sx, gy - 5*sy));
color(asym, gold);
stroke(asym, 4);
glow(asym, 8);
untraced(asym);

text(asymLab, (gx + 210, gy - 5*sy - 28), "y = 5");
display(asymLab);
color(asymLab, gold);
size(asymLab, 24);
hidden(asymLab);

dot(runDot, (gx + sx, gy - 1.25*sy), 8);
color(runDot, magenta);
glow(runDot, 10);
hidden(runDot);

counter(xRun, (gx - 145, gy + 105), 1, 0, "x = ", "");
display(xRun);
color(xRun, cyan);
size(xRun, 24);
hidden(xRun);

counter(yRun, (gx + 145, gy + 105), 1.25, 2, "value = ", "");
display(yRun);
color(yRun, lime);
size(yRun, 24);
hidden(yRun);

text(graphTitle, (gx, 145), "the graph climbs toward 5");
display(graphTitle);
color(graphTitle, cyan);
size(graphTitle, 25);
hidden(graphTitle);

rect(cubeNum, (gx - 150, gy + 190), 190, 30);
rect(cubeDen, (gx + 115, gy + 190), 70, 30);
filled(cubeNum);
filled(cubeDen);
color(cubeNum, lime);
color(cubeDen, cyan);
opacity(cubeNum, 0.55);
opacity(cubeDen, 0.55);
hidden(cubeNum);
hidden(cubeDen);

text(cubeLab1, (gx - 150, gy + 230), "leading term: 5x^3");
text(cubeLab2, (gx + 115, gy + 230), "leading term: x^3");
display(cubeLab1);
display(cubeLab2);
color(cubeLab1, lime);
color(cubeLab2, cyan);
size(cubeLab1, 18);
size(cubeLab2, 18);
hidden(cubeLab1);
hidden(cubeLab2);

text(idea, (cx, h - 110), "At infinity, only the highest powers matter.");
text(answer, (cx, h - 78), "limit = leading coefficient ratio = 5 / 1 = 5");
display(idea);
display(answer);
color(idea, fg);
color(answer, lime);
size(idea, 25);
size(answer, 32);
hidden(idea);
hidden(answer);

show(head, 0.5);
show(cap, 0.3);
show(problem, 0.5);
say(cap, "We want to see what survives when x runs far toward infinity.", 0.8);

show(stepTitle, 0.35);
par {
show(fracBox, 0.4);
show(num0, 0.4);
show(den0, 0.4);
draw(fracLine0, 0.4);
}
say(cap, "The expression has cubic terms on top and bottom.", 0.7);

par {
draw(divArrow, 0.5);
show(divText, 0.35);
}
say(cap, "Divide every term by x cubed, the largest power present.", 0.8);

par {
show(fracBox2, 0.35);
show(num1a, 0.35);
show(num1b, 0.35);
show(num1c, 0.35);
show(den1a, 0.35);
show(den1b, 0.35);
show(den1c, 0.35);
draw(fracLine1, 0.35);
}
show(vanish, 0.4);
say(cap, "Now the lower-power pieces contain 1 over x, so they shrink away.", 0.9);

par {
fade(num1b, 0.8);
fade(num1c, 0.8);
fade(den1b, 0.8);
fade(den1c, 0.8);
}
say(cap, "At infinity, those extra pieces become zero.", 0.7);

par {
draw(finalMiniLine, 0.35);
show(finalMiniTop, 0.35);
show(finalMiniBot, 0.35);
show(finalMiniEq, 0.35);
}
pulse(finalMiniEq, 0.6);
say(cap, "The surviving fraction is just 5 over 1.", 0.7);

show(graphTitle, 0.35);
par {
draw(axGraph, 0.6);
draw(ratioCurve, 1.0);
draw(asym, 0.7);
show(asymLab, 0.35);
}
say(cap, "The graph confirms the same story: it approaches the horizontal line y equals 5.", 0.9);

par {
show(runDot, 0.3);
show(xRun, 0.3);
show(yRun, 0.3);
}
par {
move(runDot, (gx + 80sx, gy - 4.76sy), 2.2, smooth);
to(xRun, value, 80, 2.2, smooth);
to(yRun, value, 4.76, 2.2, smooth);
}
say(cap, "As x gets larger, the value gets closer and closer to 5.", 0.9);

par {
show(cubeNum, 0.4);
show(cubeDen, 0.4);
show(cubeLab1, 0.4);
show(cubeLab2, 0.4);
}
say(cap, "The leading cubic terms dominate: 5x cubed compared with x cubed.", 0.8);

par {
show(idea, 0.45);
show(answer, 0.5);
}
pulse(answer, 0.7);
par {
flash(asym, gold);
flash(finalMiniEq, lime);
flash(cubeNum, lime);
flash(cubeDen, cyan);
}
say(cap, "Therefore the limit is 5.", 0.7);
wait(1.0);