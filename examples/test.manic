title("Integral Equation Quiz");
canvas("9:16");
template("shorts");

creator(me, "@anish yt=anishdev accent=cyan");
socials(me);

// --- Cast (Constructors) ---

// 1. The Quiz Question and Options
quiz(q, "Solve for continuous $u(x)$:\n$u(x) = 1 + \\int_{0}^{x} u(t) \\, dt$");
option(q, "$u(x) = x$");
option(q, "$u(x) = e^x$", correct);
option(q, "$u(x) = 1 + x$");
option(q, "$u(x) = \\cos(x)$");

// 2. Subject Figure (Visualization above the cards)
// Center at (540, 600), scale coordinates to fit within y: 430-840
let x_off = 420;
let y_off = 780;
let sx = 80;
let sy = 45;

axes(ax, (x_off, y_off), 220, 160);
color(ax, dim);

// Plot u(x) = e^x
plot(p, (x_off, y_off), sx, sy, "exp(x)", (0, 2.2));
color(p, cyan);
stroke(p, 4);

// Visual area sweep for the integral term
area(int_area, p, 0, 0);
color(int_area, magenta);
opacity(int_area, 0.35);

// Labels inside the graphic zone
text(lbl_eq, (540, 440), `$u(x) = 1 + \\text{Area}$`);
size(lbl_eq, 32);
color(lbl_eq, fg);

// Hide elements for the custom staggered entry during the quiz ask
hidden(ax);
untraced(p);
hidden(lbl_eq);

// --- Script (Timeline) ---

par {
    // Start the standard quiz loop (Ask -> Countdown -> Reveal)
    run(q, 12.0);

    // Build the visual graph synchronously while the question is being read
    seq {
        wait(1.0);
        show(ax, 0.5);
        show(lbl_eq, 0.5);

        par {
            draw(p, 3.5, smooth);
            to(int_area, x, 1.8, 3.5, smooth);
        }
    }
}

wait(2.0);