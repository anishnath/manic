title("Where Are the Roots of x² + 1 = 0?");
canvas("16:9");
template("mono");

let gx = cx - w*0.23;
let gy = cy + 40;
let sx = 70;
let sy = 70;

let rx = cx + w*0.25;
let ry = cy + 40;
let iscale = 105;

equation(head, (cx, 70), `x^2 + 1 = 0`, 54);
text(sub, (cx, 128), "On the usual real graph, roots are x-intercepts.");
size(sub, 26);
color(sub, dim);

axes(realAxes, (gx, gy), 230, 190, sx);
plot(realCurve, (gx, gy), sx, sy, "x^2+1", (-2.8, 2.8));
equation(realLabel, (gx, gy - 210), `y = x^2 + 1`, 34);
text(noCross, (gx, gy + 235), "No crossing of the real x-axis");
size(noCross, 26);
color(noCross, gold);

arrow(realAxisMark, (gx - 190, gy), (gx + 190, gy));
color(realAxisMark, dim);
stroke(realAxisMark, 3);

arrow(toComplex, (cx - 35, cy + 20), (cx + 95, cy + 20));
color(toComplex, dim);
stroke(toComplex, 4);

arrow(reAxis, (rx - 200, ry), (rx + 200, ry));
arrow(imAxis, (rx, ry + 165), (rx, ry - 165));
color(reAxis, dim);
color(imAxis, dim);
stroke(reAxis, 3);
stroke(imAxis, 3);

text(reLabel, (rx + 220, ry + 4), "real");
text(imLabel, (rx + 8, ry - 188), "imaginary");
size(reLabel, 24);
size(imLabel, 24);
color(reLabel, dim);
color(imLabel, dim);

dot(rootI, (rx, ry - iscale), 10);
dot(rootNegI, (rx, ry + iscale), 10);
color(rootI, cyan);
color(rootNegI, magenta);

equation(labelI, (rx + 48, ry - iscale), `i`, 34);
equation(labelNegI, (rx + 58, ry + iscale), `-i`, 34);
color(labelI, cyan);
color(labelNegI, magenta);

equation(complexTitle, (rx, gy - 210), `\text{complex plane}`, 34);
equation(solution, (cx, h - 105), `x^2=-1 \quad\Rightarrow\quad x=\pm i`, 44);
text(takeaway, (cx, h - 52), "So the solutions are not missing — they live off the real line.");
size(takeaway, 25);
color(takeaway, lime);

hidden(head);
hidden(sub);
hidden(realAxes);
untraced(realCurve);
hidden(realLabel);
hidden(noCross);
hidden(realAxisMark);
hidden(toComplex);
hidden(reAxis);
hidden(imAxis);
hidden(reLabel);
hidden(imLabel);
hidden(rootI);
hidden(rootNegI);
hidden(labelI);
hidden(labelNegI);
hidden(complexTitle);
hidden(solution);
hidden(takeaway);

show(head, 0.6);
show(sub, 0.6);

par {
show(realAxes, 0.8);
show(realAxisMark, 0.8);
show(realLabel, 0.8);
}

draw(realCurve, 1.4);
show(noCross, 0.8);
pulse(realAxisMark, 0.8);

show(toComplex, 0.7);

par {
show(reAxis, 0.7);
show(imAxis, 0.7);
show(reLabel, 0.7);
show(imLabel, 0.7);
show(complexTitle, 0.7);
}

par {
show(rootI, 0.5);
show(rootNegI, 0.5);
show(labelI, 0.5);
show(labelNegI, 0.5);
}

par {
pulse(rootI, 0.8);
pulse(rootNegI, 0.8);
}

show(solution, 0.8);
show(takeaway, 0.8);