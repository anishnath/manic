title("Understanding a Piecewise Function");
canvas("16:9");

template("paper");
masthead("PIECEWISE FUNCTIONS", "Q7");

// --- cast ---
text(titleq, (cx, 88), "Which rule applies to each input x?");
size(titleq, 32);
bold(titleq);
color(titleq, fg);
hidden(titleq);

text(flabel, (230, 195), "f(x) =");
size(flabel, 42);
color(flabel, fg);
hidden(flabel);

text(lbrace, (395, 195), "{");
size(lbrace, 120);
color(lbrace, fg);
hidden(lbrace);

text(expr1, (500, 145), "|x| + 3       if  x <= -3");
size(expr1, 31);
color(expr1, cyan);
hidden(expr1);

text(expr2, (500, 200), "-2x           if  -3 < x < 3");
size(expr2, 31);
color(expr2, magenta);
hidden(expr2);

text(expr3, (500, 255), "6x + 2        if  x >= 3");
size(expr3, 31);
color(expr3, gold);
hidden(expr3);

text(guide, (cx, 335), "Locate x on the number line, then choose its matching rule.");
size(guide, 24);
color(guide, dim);
hidden(guide);

line(axisline, (190, 470), (1090, 470));
color(axisline, fg);
stroke(axisline, 3);
untraced(axisline);

arrow(leftarr, (210, 470), (185, 470));
color(leftarr, fg);
stroke(leftarr, 3);
untraced(leftarr);

arrow(rightarr, (1070, 470), (1095, 470));
color(rightarr, fg);
stroke(rightarr, 3);
untraced(rightarr);

line(tickm3, (400, 452), (400, 488));
color(tickm3, fg);
stroke(tickm3, 3);
untraced(tickm3);

line(tick0, (640, 452), (640, 488));
color(tick0, fg);
stroke(tick0, 3);
untraced(tick0);

line(tick3, (880, 452), (880, 488));
color(tick3, fg);
stroke(tick3, 3);
untraced(tick3);

text(labelm3, (400, 525), "-3");
size(labelm3, 26);
color(labelm3, fg);
hidden(labelm3);

text(label0, (640, 525), "0");
size(label0, 26);
color(label0, fg);
hidden(label0);

text(label3, (880, 525), "3");
size(label3, 26);
color(label3, fg);
hidden(label3);

line(regionleft, (215, 430), (390, 430));
color(regionleft, cyan);
stroke(regionleft, 9);
untraced(regionleft);

line(regionmid, (410, 430), (870, 430));
color(regionmid, magenta);
stroke(regionmid, 9);
untraced(regionmid);

line(regionright, (890, 430), (1065, 430));
color(regionright, gold);
stroke(regionright, 9);
untraced(regionright);

dot(closedm3, (400, 430), 10);
color(closedm3, cyan);
filled(closedm3);
hidden(closedm3);

circle(openm3, (400, 430), 10);
color(openm3, magenta);
stroke(openm3, 4);
hidden(openm3);

circle(open3, (880, 430), 10);
color(open3, magenta);
stroke(open3, 4);
hidden(open3);

dot(closed3, (880, 430), 10);
color(closed3, gold);
filled(closed3);
hidden(closed3);

text(regionlab1, (300, 390), "x <= -3");
size(regionlab1, 25);
color(regionlab1, cyan);
hidden(regionlab1);

text(regionlab2, (640, 390), "-3 < x < 3");
size(regionlab2, 25);
color(regionlab2, magenta);
hidden(regionlab2);

text(regionlab3, (980, 390), "x >= 3");
size(regionlab3, 25);
color(regionlab3, gold);
hidden(regionlab3);

text(keyclosed, (355, 610), "filled dot: included");
size(keyclosed, 21);
color(keyclosed, fg);
hidden(keyclosed);

dot(keydot, (245, 605), 8);
color(keydot, fg);
filled(keydot);
hidden(keydot);

text(keyopen, (820, 610), "open dot: not included");
size(keyopen, 21);
color(keyopen, fg);
hidden(keyopen);

circle(keycircle, (690, 605), 8);
color(keycircle, fg);
stroke(keycircle, 3);
hidden(keycircle);

// --- script ---
show(titleq, 0.5);
par {
show(flabel, 0.4);
show(lbrace, 0.5);
}
stagger(0.3) {
show(expr1, 0.35);
show(expr2, 0.35);
show(expr3, 0.35);
}
show(guide, 0.45);

par {
draw(axisline, 0.6);
draw(leftarr, 0.3);
draw(rightarr, 0.3);
}
par {
draw(tickm3, 0.3);
draw(tick0, 0.3);
draw(tick3, 0.3);
}
par {
show(labelm3, 0.25);
show(label0, 0.25);
show(label3, 0.25);
}
stagger(0.3) {
draw(regionleft, 0.45);
draw(regionmid, 0.6);
draw(regionright, 0.45);
}
par {
show(regionlab1, 0.3);
show(regionlab2, 0.3);
show(regionlab3, 0.3);
}
par {
show(closedm3, 0.3);
show(openm3, 0.3);
show(open3, 0.3);
show(closed3, 0.3);
}
par {
show(keydot, 0.25);
show(keyclosed, 0.35);
show(keycircle, 0.25);
show(keyopen, 0.35);
}