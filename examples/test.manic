title("Directed Graph with Curved Edges");
canvas("16:9");

text(head, (cx, 70), "DiGraph: curved directed edges");
size(head, 28);
color(head, fg);
display(head);

dot(nodeA, (300, 300), 24);
dot(nodeB, (620, 220), 24);
dot(nodeC, (620, 430), 24);
dot(nodeD, (940, 300), 24);

color(nodeA, cyan);
color(nodeB, cyan);
color(nodeC, cyan);
color(nodeD, cyan);

text(labelA, (300, 300), "A");
text(labelB, (620, 220), "B");
text(labelC, (620, 430), "C");
text(labelD, (940, 300), "D");

size(labelA, 20);
size(labelB, 20);
size(labelC, 20);
size(labelD, 20);

color(labelA, fg);
color(labelB, fg);
color(labelC, fg);
color(labelD, fg);

spline(edgeAB, (300, 300), (390, 170), (520, 150), (620, 220));
spline(edgeBA, (620, 220), (520, 80), (390, 100), (300, 300));
spline(edgeAC, (300, 300), (400, 430), (520, 500), (620, 430));
spline(edgeCA, (620, 430), (520, 560), (390, 520), (300, 300));
spline(edgeBD, (620, 220), (730, 100), (850, 130), (940, 300));
spline(edgeDB, (940, 300), (850, 40), (730, 50), (620, 220));
spline(edgeCD, (620, 430), (730, 550), (850, 520), (940, 300));
spline(edgeDC, (940, 300), (850, 600), (730, 590), (620, 430));

arrow(headAB, (575, 190), (620, 220));
arrow(headBA, (345, 205), (300, 300));
arrow(headAC, (575, 445), (620, 430));
arrow(headCA, (345, 325), (300, 300));
arrow(headBD, (895, 235), (940, 300));
arrow(headDB, (665, 195), (620, 220));
arrow(headCD, (895, 370), (940, 300));
arrow(headDC, (665, 455), (620, 430));

color(edgeAB, dim);
color(edgeBA, dim);
color(edgeAC, dim);
color(edgeCA, dim);
color(edgeBD, dim);
color(edgeDB, dim);
color(edgeCD, dim);
color(edgeDC, dim);

color(headAB, cyan);
color(headBA, cyan);
color(headAC, cyan);
color(headCA, cyan);
color(headBD, cyan);
color(headDB, cyan);
color(headCD, cyan);
color(headDC, cyan);

stroke(edgeAB, 4);
stroke(edgeBA, 4);
stroke(edgeAC, 4);
stroke(edgeCA, 4);
stroke(edgeBD, 4);
stroke(edgeDB, 4);
stroke(edgeCD, 4);
stroke(edgeDC, 4);

stroke(headAB, 4);
stroke(headBA, 4);
stroke(headAC, 4);
stroke(headCA, 4);
stroke(headBD, 4);
stroke(headDB, 4);
stroke(headCD, 4);
stroke(headDC, 4);

untraced(edgeAB);
untraced(edgeBA);
untraced(edgeAC);
untraced(edgeCA);
untraced(edgeBD);
untraced(edgeDB);
untraced(edgeCD);
untraced(edgeDC);

untraced(headAB);
untraced(headBA);
untraced(headAC);
untraced(headCA);
untraced(headBD);
untraced(headDB);
untraced(headCD);
untraced(headDC);

caption(info, "Arrows show direction; paired curves show reciprocal edges.", (cx, h - 55), 20, dim);
hidden(info.words);   // caption words are `{id}.w0..` tagged `{id}.words` — address that, not bare `info`

show(nodeA, 0.4);
show(nodeB, 0.4);
show(nodeC, 0.4);
show(nodeD, 0.4);
show(labelA, 0.4);
show(labelB, 0.4);
show(labelC, 0.4);
show(labelD, 0.4);
show(head, 0.5);
show(info.words, 0.5);

stagger(0.12) {
draw(edgeAB, 0.7);
draw(headAB, 0.25);
draw(edgeBA, 0.7);
draw(headBA, 0.25);
draw(edgeAC, 0.7);
draw(headAC, 0.25);
draw(edgeCA, 0.7);
draw(headCA, 0.25);
draw(edgeBD, 0.7);
draw(headBD, 0.25);
draw(edgeDB, 0.7);
draw(headDB, 0.25);
draw(edgeCD, 0.7);
draw(headCD, 0.25);
draw(edgeDC, 0.7);
draw(headDC, 0.25);
}