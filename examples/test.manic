title("Parallelogram Side");
canvas("9:16");
template("neon");

creator(me, "@mathquick yt=@mathquick accent=cyan");
socials(me);

quiz(q, "A parallelogram has base 12 cm and perimeter 60 cm. Find the other side.", "glass fade");
option(q, "12 cm");
option(q, "18 cm", correct);
option(q, "24 cm");
option(q, "30 cm");

point(A, (265, 760), "A");
point(B, (815, 760), "B");
point(D, (395, 565), "D");
point(C, (945, 565), "C");

segment(AB, A, B);
segment(BC, B, C);
segment(CD, C, D);
segment(DA, D, A);

text(baseLab, (540, 815), "12 cm");
display(baseLab);
size(baseLab, 36);
color(baseLab, gold);
hidden(baseLab);

text(sideLab1, (310, 650), "x cm");
display(sideLab1);
size(sideLab1, 36);
color(sideLab1, magenta);
hidden(sideLab1);

text(sideLab2, (880, 650), "x cm");
display(sideLab2);
size(sideLab2, 36);
color(sideLab2, magenta);
hidden(sideLab2);

text(periLab, (540, 500), "perimeter = 60 cm");
display(periLab);
size(periLab, 34);
color(periLab, lime);
hidden(periLab);

color(A, fg);
color(B, fg);
color(C, fg);
color(D, fg);
size(A.label, 32);
size(B.label, 32);
size(C.label, 32);
size(D.label, 32);

color(AB, gold);
color(CD, gold);
color(BC, magenta);
color(DA, magenta);
stroke(AB, 6);
stroke(BC, 6);
stroke(CD, 6);
stroke(DA, 6);

hidden(A);
hidden(B);
hidden(C);
hidden(D);
untraced(AB);
untraced(BC);
untraced(CD);
untraced(DA);

par {
run(q, 14);
seq {
wait(1.0);
par {
show(A, 0.25);
show(B, 0.25);
draw(AB, 0.7);
}
show(baseLab, 0.35);
wait(0.15);
par {
show(D, 0.25);
show(C, 0.25);
draw(DA, 0.7);
draw(BC, 0.7);
draw(CD, 0.7);
}
par {
show(sideLab1, 0.35);
show(sideLab2, 0.35);
show(periLab, 0.35);
}
wait(8.0);
par {
pulse(sideLab1, 0.8);
pulse(sideLab2, 0.8);
}
}
}