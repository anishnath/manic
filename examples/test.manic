title("Pythagorean Identity by Area Rearrangement");
canvas("16:9");
template("mono");

let R = 150;
let theta = 0.72;
let gx = cx - w * 0.27;
let gy = cy + 55;
let xleg = R * cos(theta);
let yleg = R * sin(theta);

let cosS = xleg;
let sinS = yleg;
let startY = h - 128;
let cosL = cx - 145;
let sinL = cx + 35;

let uLeft = cx + 265;
let uTop = h - 300;
let hCos = cosS * cosS / R;
let hSin = sinS * sinS / R;

equation(head, (cx, 72), `\sin^2\theta+\cos^2\theta=1`, 54);
text(narr, (cx, h - 42), "A unit radius turns algebra into area.");
size(narr, 26);
color(narr, dim);

point(O, (gx, gy), "O");
point(A, (gx + R, gy), "1");
point(P, (gx + xleg, gy - yleg), "P");
foot(C, P, O, A);

circle2(unitCircle, O, A);
segment(baseCos, O, C);
segment(heightSin, C, P);
segment(radiusOne, O, P);
rightangle(corner, O, C, P);

equation(cosLab, (gx + xleg / 2, gy + 34), `\cos\theta`, 28);
equation(sinLab, (gx + xleg + 48, gy - yleg / 2), `\sin\theta`, 28);
equation(radLab, (gx + xleg / 2 - 20, gy - yleg / 2 - 30), `1`, 30);
equation(thetaLab, (gx + 42, gy - 20),`\theta`, 28);

polygon(sqCos, (cosL, startY - cosS), (cosL + cosS, startY - cosS), (cosL + cosS, startY), (cosL, startY), cyan);
polygon(sqSin, (sinL, startY - sinS), (sinL + sinS, startY - sinS), (sinL + sinS, startY), (sinL, startY), magenta);

equation(sqCosLab, (cosL + cosS / 2, startY - cosS / 2), `\cos^2\theta`, 25);
equation(sqSinLab, (sinL + sinS / 2, startY - sinS / 2), `\sin^2\theta`, 25);

polygon(stripSin, (uLeft, uTop), (uLeft + R, uTop), (uLeft + R, uTop + hSin), (uLeft, uTop + hSin), magenta);
polygon(stripCos, (uLeft, uTop + hSin), (uLeft + R, uTop + hSin), (uLeft + R, uTop + R), (uLeft, uTop + R), cyan);

line(uTopLine, (uLeft, uTop), (uLeft + R, uTop));
line(uRightLine, (uLeft + R, uTop), (uLeft + R, uTop + R));
line(uBottomLine, (uLeft + R, uTop + R), (uLeft, uTop + R));
line(uLeftLine, (uLeft, uTop + R), (uLeft, uTop));
tag(uTopLine, unitOutline);
tag(uRightLine, unitOutline);
tag(uBottomLine, unitOutline);
tag(uLeftLine, unitOutline);

equation(unitLab, (uLeft + R / 2, uTop - 34), `1^2`, 32);
equation(stripSinLab, (uLeft + R / 2, uTop + hSin / 2), `\sin^2\theta`, 24);
equation(stripCosLab, (uLeft + R / 2, uTop + hSin + hCos / 2), `\cos^2\theta`, 24);

arrow(moveArrowA, (cosL + cosS + 25, startY - cosS / 2), (uLeft - 30, uTop + hSin + hCos / 2));
arrow(moveArrowB, (sinL + sinS + 20, startY - sinS / 2), (uLeft - 30, uTop + hSin / 2));

equation(theorem, (cx + 235, gy - 115), `(\cos\theta)^2+(\sin\theta)^2=1^2`, 36);
equation(finalEq, (cx, 150), `\boxed{\cos^2\theta+\sin^2\theta=1}`, 50);

color(unitCircle, dim);
color(baseCos, cyan);
color(heightSin, magenta);
color(radiusOne, gold);
color(corner, fg);
color(O.label, dim);
color(A.label, gold);
color(P.label, fg);
color(cosLab, cyan);
color(sinLab, magenta);
color(radLab, gold);
color(thetaLab, fg);
color(unitOutline, gold);
color(unitLab, gold);
color(moveArrowA, dim);
color(moveArrowB, dim);
color(theorem, fg);
color(finalEq, lime);

stroke(unitCircle, 3);
stroke(baseCos, 5);
stroke(heightSin, 5);
stroke(radiusOne, 5);
stroke(unitOutline, 4);
stroke(moveArrowA, 3);
stroke(moveArrowB, 3);

opacity(sqCos, 0.55);
opacity(sqSin, 0.55);
opacity(stripCos, 0.55);
opacity(stripSin, 0.55);

z(unitOutline, 5);
z(unitLab, 6);
z(stripSinLab, 6);
z(stripCosLab, 6);

morph(sqCos, stripCos);
morph(sqSin, stripSin);

hidden(head);
hidden(narr);
hidden(O);
hidden(A);
hidden(P);
hidden(C);
untraced(unitCircle);
untraced(baseCos);
untraced(heightSin);
untraced(radiusOne);
untraced(corner);
hidden(cosLab);
hidden(sinLab);
hidden(radLab);
hidden(thetaLab);
hidden(sqCos);
hidden(sqSin);
hidden(sqCosLab);
hidden(sqSinLab);
hidden(stripCos);
hidden(stripSin);
untraced(unitOutline);
hidden(unitLab);
hidden(stripSinLab);
hidden(stripCosLab);
hidden(moveArrowA);
hidden(moveArrowB);
hidden(theorem);
hidden(finalEq);

show(head, 0.7);
show(narr, 0.6);

say(narr, "Start with a point on the unit circle: the radius has length 1.", 0.7);
par {
draw(unitCircle, 1.1);
show(O, 0.5);
show(A, 0.5);
show(P, 0.5);
}

par {
draw(radiusOne, 0.8);
show(radLab, 0.5);
}
show(thetaLab, 0.5);

say(narr, "Drop the vertical leg. The horizontal and vertical lengths are cosine and sine.", 0.9);
par {
show(C, 0.4);
draw(baseCos, 0.8);
draw(heightSin, 0.8);
draw(corner, 0.5);
}
par {
show(cosLab, 0.5);
show(sinLab, 0.5);
}

say(narr, "Now square those two legs: their areas are cos²θ and sin²θ.", 0.9);
par {
show(sqCos, 0.7);
show(sqSin, 0.7);
show(sqCosLab, 0.7);
show(sqSinLab, 0.7);
}

say(narr, "The hypotenuse is the unit radius, so its square has area 1.", 0.8);
par {
draw(unitOutline, 0.9);
show(unitLab, 0.7);
show(theorem, 0.7);
}

say(narr, "Rearrange equal areas: the two leg-squares exactly fill the unit square.", 0.9);
par {
show(moveArrowA, 0.4);
show(moveArrowB, 0.4);
}
par {
fade(sqCosLab, 0.35);
fade(sqSinLab, 0.35);
fade(moveArrowA, 0.35);
fade(moveArrowB, 0.35);
}
par {
to(sqCos, morph, 1, 1.25, smooth);
to(sqSin, morph, 1, 1.25, smooth);
}
par {
show(stripCosLab, 0.5);
show(stripSinLab, 0.5);
pulse(unitOutline, 0.8);
}

say(narr, "That filled unit square is the identity: no algebra trick, just conserved area.", 0.8);
show(finalEq, 0.8);
pulse(finalEq, 0.9);